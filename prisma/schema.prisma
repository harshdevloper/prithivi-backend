generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "darwin-arm64"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  ENDED
}

enum ClaimStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TransactionType {
  CREDIT
  DEBIT
}

enum CoinPurchaseStatus {
  CREATED
  CAPTURED
}

enum NotificationType {
  SYSTEM
  CAMPAIGN
  CLAIM
  WALLET
}

enum PushLogStatus {
  QUEUED
  SCHEDULED
  SENT
  PARTIAL
  FAILED
}

/// Publish lifecycle shared by all Hot Offers CMS content.
enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum OfferEventType {
  VIEW
  CLICK
  DOWNLOAD
}

enum OfferEventSource {
  APP
  WEBSITE
}

/// Review lifecycle for a user's proof-of-completion screenshot.
enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
  NEED_MORE_PROOF
  CANCELLED
}

enum OfferDifficulty {
  EASY
  MEDIUM
  HARD
}

/// Lifecycle of a coin-redemption request. APPROVED = awaiting voucher
/// (manual mode or provider failure); FULFILLED = voucher delivered.
enum RedemptionStatus {
  PENDING
  APPROVED
  REJECTED
  FULFILLED
  FAILED
}

enum FraudEventType {
  DUPLICATE_IMAGE
  DAILY_LIMIT
  EXCESS_PENDING
  MANUAL
}

enum GameMatchStatus {
  IN_PROGRESS
  WON
  LOST
  DRAW
}

/// Bet types the roulette engine can settle. The five required types ship now;
/// the engine's resolver map makes LOW/HIGH/DOZEN/COLUMN a small future add.
enum RouletteBetType {
  ODD
  EVEN
  RED
  BLACK
  NUMBER
}

enum RouletteRoundStatus {
  SETTLED
  VOID
}

enum RouletteProbabilityMode {
  FAIR
  WEIGHTED
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  name         String
  avatarUrl    String?
  googleId     String?   @unique
  firebaseUid  String?   @unique
  role         Role      @default(USER)
  isActive     Boolean   @default(true)
  referralCode String?   @unique
  referredById String?
  referredAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  referredBy User?  @relation("Referrals", fields: [referredById], references: [id])
  referrals  User[] @relation("Referrals")

  wallet              Wallet?
  refreshTokens       RefreshToken[]
  claims              Claim[]
  notifications       Notification[]
  campaigns           Campaign[]          @relation("CampaignCreator")
  reviewedClaims      Claim[]             @relation("ClaimReviewer")
  analyticsEvents     AnalyticsEvent[]
  deviceTokens        DeviceToken[]
  sentPushLogs        PushLog[]           @relation("PushLogSender")
  offerSubmissions    OfferSubmission[]   @relation("OfferSubmissionUser")
  reviewedSubmissions OfferSubmission[]   @relation("OfferSubmissionReviewer")
  fraudLogs           FraudLog[]
  redemptions         Redemption[]        @relation("RedemptionUser")
  reviewedRedemptions Redemption[]        @relation("RedemptionReviewer")
  gameMatches         GameMatch[]
  missionCompletions  MissionCompletion[]
  rouletteRounds      RouletteRound[]
  coinPurchases       CoinPurchase[]

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  userId    String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model Campaign {
  id           String         @id @default(uuid())
  title        String
  description  String
  rewardAmount Decimal        @db.Decimal(12, 2)
  budget       Decimal?       @db.Decimal(14, 2)
  status       CampaignStatus @default(DRAFT)
  startsAt     DateTime?
  endsAt       DateTime?
  createdById  String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  createdBy User    @relation("CampaignCreator", fields: [createdById], references: [id])
  claims    Claim[]

  @@index([status])
  @@index([createdById])
  @@map("campaigns")
}

model Claim {
  id           String      @id @default(uuid())
  campaignId   String
  userId       String
  status       ClaimStatus @default(PENDING)
  rewardAmount Decimal     @db.Decimal(12, 2)
  note         String?
  reviewNote   String?
  reviewedById String?
  reviewedAt   DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy User?    @relation("ClaimReviewer", fields: [reviewedById], references: [id])

  @@unique([campaignId, userId])
  @@index([userId])
  @@index([status])
  @@map("claims")
}

model Wallet {
  id        String   @id @default(uuid())
  userId    String   @unique
  balance   Decimal  @default(0) @db.Decimal(14, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]

  @@map("wallets")
}

model WalletTransaction {
  id           String          @id @default(uuid())
  walletId     String
  type         TransactionType
  amount       Decimal         @db.Decimal(12, 2)
  balanceAfter Decimal         @db.Decimal(14, 2)
  reference    String?
  description  String?
  createdAt    DateTime        @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId, createdAt])
  @@map("wallet_transactions")
}

/// Razorpay-backed coin order. The immutable price/coin snapshot makes later
/// admin rate changes safe, while unique provider ids make verification and
/// wallet crediting idempotent.
model CoinPurchase {
  id                String             @id @default(uuid())
  userId            String
  razorpayOrderId   String             @unique
  razorpayPaymentId String?            @unique
  amountPaise       Int
  coins             Int
  packCount         Int
  status            CoinPurchaseStatus @default(CREATED)
  capturedAt        DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("coin_purchases")
}

model DeviceToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  platform  String   @default("android")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("device_tokens")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType @default(SYSTEM)
  title     String
  body      String
  imageUrl  String?
  route     String? // in-app deep link the client opens on tap, e.g. /campaigns/<id>
  data      Json? // extra key-value payload mirrored into the FCM message
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("notifications")
}

/// One row per admin send — the delivery audit trail behind GET /notifications/history.
model PushLog {
  id           String           @id @default(uuid())
  audience     String // "all" | "user" | "topic"
  userId       String? // target when audience = "user"
  topic        String? // target when audience = "topic"
  type         NotificationType @default(SYSTEM)
  title        String
  body         String
  imageUrl     String?
  route        String?
  data         Json?
  silent       Boolean          @default(false)
  scheduledAt  DateTime?
  status       PushLogStatus    @default(QUEUED)
  successCount Int              @default(0)
  failureCount Int              @default(0)
  error        String?
  sentById     String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  sentBy User @relation("PushLogSender", fields: [sentById], references: [id])

  @@index([createdAt])
  @@map("push_logs")
}

/// Configurable reward-system settings. Only the value is stored — the type,
/// category, label, description and default live in the code registry
/// (src/modules/settings), so this table just holds admin overrides.
model Setting {
  key         String   @id
  value       String
  updatedById String?
  updatedAt   DateTime @updatedAt

  @@map("settings")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  userEmail  String?
  action     String // e.g. "PATCH /api/v1/claims/:id/review"
  method     String
  path       String
  statusCode Int
  ip         String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([createdAt])
  @@map("audit_logs")
}

model AnalyticsEvent {
  id        String   @id @default(uuid())
  name      String
  userId    String?
  metadata  Json?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([name, createdAt])
  @@map("analytics_events")
}

// ---------------------------------------------------------------------------
// Hot Offers (CMS-driven offers funnel: app -> feedback page -> website -> store)
// ---------------------------------------------------------------------------

/// A backend-managed offer category used across the app and web experience.
model OfferCategory {
  id        String        @id @default(uuid())
  slug      String        @unique // stable key used in URLs and deep links
  title     String
  subtitle  String? // small description under the title
  imageUrl  String?
  priority  Int           @default(0) // higher shows first
  featured  Boolean       @default(false)
  status    ContentStatus @default(DRAFT)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  deletedAt DateTime? // soft delete — queries must filter deletedAt: null

  feedbackPage FeedbackPage?
  offers       Offer[]
  events       OfferEvent[]

  @@index([status, priority])
  @@map("offer_categories")
}

/// The in-app CMS page a category opens (banner, benefits, CTA to the website).
model FeedbackPage {
  id            String        @id @default(uuid())
  categoryId    String        @unique
  bannerUrl     String?
  title         String
  description   String
  benefits      Json? // string[] shown as a checklist
  rewardPoints  Int           @default(0)
  buttonText    String        @default("Download")
  buttonVisible Boolean       @default(true)
  websiteUrl    String // external URL the button opens
  status        ContentStatus @default(DRAFT)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?

  category OfferCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@map("feedback_pages")
}

/// One offer card on the website plus everything on its details page.
model Offer {
  id               String          @id @default(uuid())
  categoryId       String
  slug             String          @unique
  title            String
  appName          String?
  logoUrl          String?
  thumbnailUrl     String? // card image
  bannerUrl        String? // details hero image
  shortDescription String // card copy
  description      String // details copy
  features         Json? // string[]
  instructions     Json? // ordered string[] ("1. Install", "2. Open", ...)
  requirements     Json? // string[] ("Android 10+", "New users only", ...)
  terms            String?
  warning          String?
  rewardAmount     Decimal         @db.Decimal(12, 2) // credited to the wallet when a proof is approved
  rewardCoins      Int             @default(0) // display-layer gamification coins (not a second currency)
  rewardLabel      String? // free-form display, e.g. "Up to 150 + bonus"
  taskDescription  String? // the concrete task, e.g. "Reach level 5 within 3 days"
  difficulty       OfferDifficulty @default(EASY)
  estimatedTime    String? // e.g. "10 min"
  rating           Decimal?        @db.Decimal(2, 1) // admin-set display rating 0.0-5.0
  playStoreUrl     String
  isProduct        Boolean         @default(false) // product offers surface on the app's Products tab
  brandLogoUrl     String? // brand mark shown on product cards
  featured         Boolean         @default(false)
  trending         Boolean         @default(false)
  expiresAt        DateTime? // hidden from public lists after this moment
  maxUsers         Int? // cap on distinct participants — enforced at submission (Module 4)
  maxRewards       Int? // cap on approved rewards — enforced at approval (Module 4)
  dailyLimit       Int? // per-user submissions per day — enforced at submission (Module 4)
  priority         Int             @default(0)
  status           ContentStatus   @default(DRAFT)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  deletedAt        DateTime?

  category    OfferCategory     @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  events      OfferEvent[]
  submissions OfferSubmission[]

  @@index([categoryId, status, priority])
  @@index([status, featured])
  @@map("offers")
}

/// A logged-in user's proof-of-completion screenshot for an offer. Admin
/// reviews it; on approval the offer's reward is credited to the wallet.
model OfferSubmission {
  id            String           @id @default(uuid())
  offerId       String
  userId        String
  screenshotUrl String
  note          String?
  status        SubmissionStatus @default(PENDING)
  reviewNote    String?
  reviewedById  String?
  reviewedAt    DateTime?
  rewardAmount  Decimal          @db.Decimal(12, 2) // snapshot of the offer reward at submit time
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  offer      Offer             @relation(fields: [offerId], references: [id], onDelete: Cascade)
  user       User              @relation("OfferSubmissionUser", fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy User?             @relation("OfferSubmissionReviewer", fields: [reviewedById], references: [id])
  images     SubmissionImage[]
  fraudLogs  FraudLog[]

  @@unique([offerId, userId]) // one submission per user per offer (resubmit reuses the row)
  @@index([status, createdAt])
  @@index([userId])
  @@map("offer_submissions")
}

/// Append-only record of every proof image (one per submit/resubmit attempt).
/// Powers duplicate-image detection (hash), the daily-limit counter, and audit.
model SubmissionImage {
  id           String   @id @default(uuid())
  submissionId String
  url          String
  hash         String // SHA-256 of the image bytes, computed server-side
  byteSize     Int
  createdAt    DateTime @default(now())

  submission OfferSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([hash])
  @@index([submissionId, createdAt])
  @@map("submission_images")
}

/// A user's request to convert wallet coins into a gift voucher. Coins are
/// debited up-front (refunded on rejection); the voucher is issued via the
/// configured provider or entered manually by a super admin.
model Redemption {
  id             String           @id @default(uuid())
  userId         String
  coins          Decimal          @db.Decimal(12, 2) // amount debited from the wallet
  status         RedemptionStatus @default(PENDING)
  provider       String? // "plum" | "manual"
  voucherCode    String?
  voucherUrl     String?
  providerRef    String? // provider transaction/batch id (e.g. Plum batchId)
  note           String? // admin note set at review time
  failReason     String? // last provider error (status APPROVED = queued for manual)
  voucherOfferId String? // catalog item this redemption is for (null = legacy amount-only)
  reviewedById   String?
  reviewedAt     DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  user         User          @relation("RedemptionUser", fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy   User?         @relation("RedemptionReviewer", fields: [reviewedById], references: [id])
  // Restrict (not the optional-relation default SetNull): deleting an offer
  // must never silently strip attribution off an in-flight redemption.
  voucherOffer VoucherOffer? @relation(fields: [voucherOfferId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([status])
  @@map("redemptions")
}

/// Admin-curated voucher catalog shown in the app's coupon store. When the
/// Xoxoday Plum provider is configured, providerBrandId + denomination drive the
/// auto-issue call; otherwise redemptions fall back to manual fulfillment.
model VoucherOffer {
  id              String   @id @default(uuid())
  title           String
  brand           String // display brand, e.g. "Amazon"
  description     String?
  imageUrl        String?
  coinCost        Int // coins debited from the wallet
  denomination    Decimal  @db.Decimal(12, 2) // voucher face value (currency)
  provider        String   @default("manual") // "plum" | "manual"
  providerBrandId String? // Plum Reward Link campaign ID when provider = "plum"
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  redemptions Redemption[]

  @@index([isActive, sortOrder])
  @@map("voucher_offers")
}

/// A logged suspicious event contributing to a user's fraud score.
model FraudLog {
  id           String         @id @default(uuid())
  userId       String
  submissionId String?
  type         FraudEventType
  score        Int            @default(0)
  detail       String?
  createdAt    DateTime       @default(now())

  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  submission OfferSubmission? @relation(fields: [submissionId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([createdAt])
  @@map("fraud_logs")
}

/// Append-only analytics stream. Deliberately immutable: no updatedAt,
/// deletedAt or status — views/clicks/downloads are facts, not content.
/// CTR = CLICK/VIEW, conversion = DOWNLOAD/VIEW, uniques = distinct sessionId.
model OfferEvent {
  id         String           @id @default(uuid())
  offerId    String?
  categoryId String?
  type       OfferEventType
  source     OfferEventSource
  sessionId  String // anonymous visitor/device id from the client
  userId     String? // set when a signed-in app user triggers the event
  createdAt  DateTime         @default(now())

  offer    Offer?         @relation(fields: [offerId], references: [id], onDelete: Cascade)
  category OfferCategory? @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([offerId, type, createdAt])
  @@index([categoryId, type, createdAt])
  @@index([createdAt])
  @@map("offer_events")
}

/// One 3-piece tic-tac-toe match. `state` = { board, xOrder, oOrder, plies }.
model GameMatch {
  id           String          @id @default(uuid())
  userId       String
  state        Json
  status       GameMatchStatus @default(IN_PROGRESS)
  coinsAwarded Decimal?        @db.Decimal(12, 2)
  difficulty   String
  hintsEnabled Boolean         @default(false)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("game_matches")
}

/// A global, versioned probability configuration for the roulette wheel. FAIR =
/// every number 0..36 equally likely. WEIGHTED = `numberWeights` (a 37-length
/// integer array indexed by number) biases outcomes. Timed schedules select the
/// live profile; `active`/`effectiveFrom` remain only for legacy API responses.
/// Each round snapshots its resolved schedule/profile so history never changes.
model RouletteProbabilityProfile {
  id            String                  @id @default(uuid())
  name          String
  mode          RouletteProbabilityMode @default(WEIGHTED)
  numberWeights Json // int[37]; ignored when mode = FAIR
  estimatedRtp  Decimal                 @db.Decimal(12, 4) // e.g. 0.9730; supports high admin-configured payouts
  active        Boolean                 @default(false)
  effectiveFrom DateTime                @default(now())
  createdById   String?
  createdAt     DateTime                @default(now())

  rounds    RouletteRound[]
  schedules RouletteProbabilitySchedule[]

  @@index([active])
  @@map("roulette_probability_profiles")
}

/// An immutable, finite UTC window during which one probability profile is
/// selected. Window semantics are half-open: startsAt <= now < endsAt.
/// Cancellation is the only supported mutation. A PostgreSQL exclusion
/// constraint in the migration prevents overlapping non-cancelled windows.
model RouletteProbabilitySchedule {
  id            String    @id @default(uuid())
  profileId     String
  startsAt      DateTime  @db.Timestamptz(3)
  endsAt        DateTime  @db.Timestamptz(3)
  reason        String
  createdById   String?
  createdAt     DateTime  @default(now()) @db.Timestamptz(3)
  cancelledAt   DateTime? @db.Timestamptz(3)
  cancelledById String?
  cancelReason  String?

  profile RouletteProbabilityProfile @relation(fields: [profileId], references: [id], onDelete: Restrict)
  rounds  RouletteRound[]

  @@index([startsAt, endsAt])
  @@index([profileId, startsAt])
  @@map("roulette_probability_schedules")
}

/// One roulette spin — the bet, the server-decided result, the wallet outcome,
/// and the provably-fair seed data. Created and settled atomically in a single
/// request, so `status` is SETTLED for every real play. `configSnapshot` freezes
/// the payouts + probability weights used, and `idempotencyKey` (unique per
/// user) makes a duplicate tap / retry return the same round instead of a new one.
model RouletteRound {
  id                    String                  @id @default(uuid())
  userId                String
  betType               RouletteBetType
  selectedNumber        Int? // set only for NUMBER bets (0..36)
  betAmount             Decimal                 @db.Decimal(12, 2) // effective stake used for payout
  usedFreeGame          Boolean                 @default(false)
  winningNumber         Int
  winningColour         String // RED | BLACK | GREEN
  parity                String // ODD | EVEN | NONE (0 is NONE)
  won                   Boolean
  payoutMultiplier      Int // profit "X to 1" multiplier applied (0 on loss)
  payoutAmount          Decimal                 @db.Decimal(12, 2) // total credited on win (0 on loss)
  netResult             Decimal                 @db.Decimal(12, 2) // payout - stake (paid) / payout (free); can be negative
  status                RouletteRoundStatus     @default(SETTLED)
  probabilityMode       RouletteProbabilityMode
  configSnapshot        Json // { payouts, minBet, maxBet, weights?, profileId? } frozen at bet time
  probabilityProfileId  String?
  probabilityScheduleId String?
  policyResolvedAt      DateTime                @default(now()) @db.Timestamptz(3)
  serverSeed            String // revealed after settlement (single-request play)
  serverSeedHash        String // sha256(serverSeed), committed on the round
  clientSeed            String
  nonce                 Int                     @default(0)
  idempotencyKey        String
  createdAt             DateTime                @default(now())
  settledAt             DateTime?

  user     User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile  RouletteProbabilityProfile?  @relation(fields: [probabilityProfileId], references: [id])
  schedule RouletteProbabilitySchedule? @relation(fields: [probabilityScheduleId], references: [id], onDelete: Restrict)

  @@unique([userId, idempotencyKey])
  @@index([userId, createdAt])
  @@index([createdAt])
  @@index([winningNumber])
  @@index([betType])
  @@index([probabilityScheduleId])
  @@map("roulette_rounds")
}

model Mission {
  id          String        @id @default(uuid())
  title       String
  description String
  rewardCoins Decimal       @db.Decimal(12, 2)
  status      ContentStatus @default(DRAFT)
  sortOrder   Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  completions MissionCompletion[]

  @@index([status, sortOrder])
  @@map("missions")
}

model MissionCompletion {
  id           String      @id @default(uuid())
  missionId    String
  userId       String
  status       ClaimStatus @default(PENDING)
  note         String?
  reviewedById String?
  reviewedAt   DateTime?
  createdAt    DateTime    @default(now())

  mission Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([missionId, userId])
  @@index([userId])
  @@index([status])
  @@map("mission_completions")
}

/// Admin-overridable in-app graphic. Slot registry (keys, pages, labels)
/// lives in code (src/modules/app-assets/registry.ts); the DB stores only overrides.
model AppAsset {
  id          String   @id @default(uuid())
  slotKey     String   @unique
  imageUrl    String
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("app_assets")
}
