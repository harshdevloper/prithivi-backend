# Production template — copy to .env.production on the server and fill in.
# NEVER commit the real .env.production.
NODE_ENV=production
PORT=4000
HOST=127.0.0.1              # bind to loopback; nginx is the public entry point
API_PREFIX=/api/v1
LOG_LEVEL=info
APP_URL=https://prithivi-backend.onrender.com
TRUST_PROXY=true            # behind nginx

# Connection pooling is configured in the URL (see docs/ENVIRONMENT.md):
#   connection_limit = max pool size PER PM2 INSTANCE (keep instances × limit < max_connections)
#   pool_timeout     = seconds to wait for a free connection
DATABASE_URL=postgresql://rewardhub:CHANGE_ME@localhost:5432/rewardhub?schema=public&connection_limit=10&pool_timeout=20
REDIS_URL=redis://127.0.0.1:6379

# Generate with: openssl rand -hex 64
JWT_SECRET=CHANGE_ME
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=money-marathon
JWT_AUDIENCE=money-marathon-clients


# Firebase Admin (mobile app auth). On a server, base64-encode the JSON so it
# fits on one line:  base64 -w0 firebase-service-account.json
FIREBASE_SERVICE_ACCOUNT=CHANGE_ME_base64_of_service_account_json
FIREBASE_PROJECT_ID=your-firebase-project-id

# Comma-separated exact origins — no wildcards.
CORS_ORIGIN=https://moneymarathon.in,https://admin.yourdomain.com
SWAGGER_ROUTE=/docs
SWAGGER_ENABLED=false       # keep API docs off public production

RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1 minute

# Recommended in production (otherwise files land on local disk in UPLOADS_DIR):
CLOUDINARY_URL=cloudinary://CHANGE_ME:CHANGE_ME@your-cloud
UPLOADS_DIR=/var/www/rewardhub/uploads
UPLOAD_MAX_BYTES=5242880

ADMIN_EMAIL=puniaprathvi860@gmail.com
ADMIN_NAME=Money Marathon Admin

# Xoxoday Plum production Reward Link API. Store all values as server-side
# secrets; never expose them to the web or mobile clients.
XOXODAY_BASE_URL=https://accounts.xoxoday.com/chef/v1/oauth
XOXODAY_ACCESS_TOKEN=CHANGE_ME
XOXODAY_REFRESH_TOKEN=CHANGE_ME
XOXODAY_CLIENT_ID=CHANGE_ME
XOXODAY_CLIENT_SECRET=CHANGE_ME
# Mount a private persistent disk at /var/data before enabling this.
XOXODAY_TOKEN_STATE_FILE=/var/data/xoxoday-tokens.json
XOXODAY_CAMPAIGN_ID=CHANGE_ME
XOXODAY_LINK_EXPIRY_DAYS=90
