# Development environment — safe defaults, no real secrets.
NODE_ENV=development
PORT=4000
HOST=0.0.0.0
API_PREFIX=/api/v1
LOG_LEVEL=debug
# localhost works for the PC (admin/website) and the phone via `adb reverse
# tcp:4000 tcp:4000`, so uploaded image URLs are reachable everywhere over USB.
# In production set this to your public API origin.
APP_URL=http://localhost:4000
TRUST_PROXY=false

# socket_timeout: abandon a query whose connection stalls (flaky route to Neon)
# so the pool slot is freed instead of being held forever -> no more P2024 pileups.
DATABASE_URL=postgresql://neondb_owner:npg_Ba6FMLbPo7Up@ep-crimson-feather-aogarpxs-pooler.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connect_timeout=30&pool_timeout=30&connection_limit=10&socket_timeout=45
# uncomment next line if you use Prisma <5.10
# DATABASE_URL_UNPOOLED="postgresql://neondb_owner:npg_Ba6FMLbPo7Up@ep-crimson-feather-aogarpxs.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
REDIS_URL=rediss://default:gQAAAAAAAmymAAIgcDFhZjIwMGFlOWU5NWY0M2MwYmY0Njg2NTFmODgxMDcxZA@classic-ghost-158886.upstash.io:6379
# DATABASE_URL_UNPOOLED="postgresql://neondb_owner:npg_k3UJznmZNcD8@ep-young-recipe-aoc1l8mo.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
JWT_SECRET=dev-secret-do-not-use-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=rewardhub
JWT_AUDIENCE=rewardhub-clients

# Firebase Admin — verifies Firebase ID tokens (the only auth provider).
# Firebase Console -> Project settings -> Service accounts -> Generate new private key.
# Save the JSON as backend/firebase-service-account.json (git-ignored) and set the path,
# OR paste the base64 of the JSON into FIREBASE_SERVICE_ACCOUNT.
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# FIREBASE_SERVICE_ACCOUNT=
FIREBASE_PROJECT_ID=rewardhub-99c60

CORS_ORIGIN=http://localhost:5173
SWAGGER_ROUTE=/docs
SWAGGER_ENABLED=true

RATE_LIMIT_MAX=1000
RATE_LIMIT_WINDOW=1 minute

# CLOUDINARY_URL=cloudinary://key:secret@cloud-name
UPLOADS_DIR=uploads
UPLOAD_MAX_BYTES=5242880

ADMIN_EMAIL=puniaprathvi860@gmail.com
ADMIN_NAME=RewardHub Admin
