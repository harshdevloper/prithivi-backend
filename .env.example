NODE_ENV=development
PORT=4000
HOST=0.0.0.0
API_PREFIX=/api/v1
APP_URL=http://localhost:4000
TRUST_PROXY=false

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/money_marathon?schema=public
JWT_SECRET=replace-with-a-long-random-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=money-marathon
JWT_AUDIENCE=money-marathon-clients

FIREBASE_SERVICE_ACCOUNT_PATH=
FIREBASE_SERVICE_ACCOUNT=
FIREBASE_PROJECT_ID=

CORS_ORIGIN=http://localhost:5173,http://localhost:5174
SWAGGER_ROUTE=/docs
SWAGGER_ENABLED=true
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1 minute

# Xoxoday Plum sandbox. Generate these under Plum Admin -> Settings -> API.
# Leave XOXODAY_ACCESS_TOKEN empty to keep manual voucher fulfillment enabled.
XOXODAY_BASE_URL=https://stagingstores.xoxoday.com/chef/v1/oauth
XOXODAY_ACCESS_TOKEN=
XOXODAY_REFRESH_TOKEN=
XOXODAY_CLIENT_ID=
XOXODAY_CLIENT_SECRET=
# Optional locally; use a private persistent disk in production.
XOXODAY_TOKEN_STATE_FILE=
XOXODAY_CAMPAIGN_ID=
XOXODAY_LINK_EXPIRY_DAYS=90

CLOUDINARY_URL=
UPLOADS_DIR=uploads
UPLOAD_MAX_BYTES=5242880

ADMIN_EMAIL=puniaprathvi860@gmail.com
ADMIN_NAME=Money Marathon Admin
